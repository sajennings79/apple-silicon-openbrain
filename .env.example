DATABASE_URL=postgres://localhost:5432/openbrain
REDIS_URL=redis://localhost:6379
EMBEDDING_URL=http://localhost:6278
LLM_URL=http://localhost:8000

# openbrain owns local inference: it runs its own mlx_lm server (com.openbrain.llm)
# on LLM_URL, and install-services.sh stamps LLM_MODEL into that plist's --model.
# LLM_MODEL is therefore the single source of truth for which model is served.
# Default is sized for 16GB RAM Apple Silicon (~4.5GB on disk, fits with Postgres/Redis/macOS).
# 32GB users: mlx-community/Qwen3.5-27B-4bit  |  64GB+: mlx-community/Qwen3.5-122B-A10B-4bit
LLM_MODEL=mlx-community/Qwen3-8B-4bit

MCP_PORT=6277
MCP_HOST=0.0.0.0
UI_PORT=6279
AUTH_TOKEN=change-me-to-a-secure-token

# Firecrawl is the web scraper used for URL ingestion. Required — set your API
# key from https://firecrawl.dev. Without it, /api/ingest will fail.
FIRECRAWL_API_KEY=

# Mail integration via gog (https://github.com/steipete/gogcli) is opt-in.
# When the launchd-managed MCP server needs to read your inbox via `gog gmail`,
# it has no TTY for the keyring prompt — so set this to your gog keyring
# password. The .env file is gitignored. If unset, mail sources will fail with
# "no TTY available for keyring file backend password prompt".
# GOG_KEYRING_PASSWORD=

# DISABLE_ENRICHMENT=true  # Uncomment to skip LLM enrichment (useful for initial setup)
